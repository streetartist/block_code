[gd_resource type="Resource" load_steps=2 format=3]

[ext_resource type="Script" path="res://addons/block_code/code_generation/block_definition.gd" id="1_number_not_between"]

[resource]
script = ExtResource("1_number_not_between")
name = &"number_not_between"
description = "Whether a number is outside a range."
category = "Logic | Comparison"
type = 3
variant_type = 1
display_template = "{value: FLOAT} is not between {min: FLOAT} and {max: FLOAT}"
code_template = "{value} < {min} or {value} > {max}"
defaults = {
"max": 1.0,
"min": 0.0,
"value": 0.0
}
