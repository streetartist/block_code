[ext_resource type="Script" path="res://addons/block_code/code_generation/block_definition.gd" id="1_set_max_fps"]

[resource]
script = ExtResource("1_set_max_fps")
name = &"set_max_fps"
description = "Set maximum frames per second. Use 0 for unlimited."
category = "Lifecycle"
type = 2
variant_type = 0
display_template = "set max fps to {fps: INT}"
code_template = "Engine.max_fps = {fps}"
defaults = {
"fps": 0
}
