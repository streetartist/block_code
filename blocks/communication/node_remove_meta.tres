[ext_resource type="Script" path="res://addons/block_code/code_generation/block_definition.gd" id="1_node_remove_meta"]

[resource]
script = ExtResource("1_node_remove_meta")
name = &"node_remove_meta"
description = "Remove metadata from a node."
category = "Communication | Nodes"
type = 2
variant_type = 0
display_template = "remove metadata {key: STRING} from {node: OBJECT}"
code_template = "{node}.remove_meta({key})"
defaults = {
"key": "key"
}
