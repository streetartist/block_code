[gd_resource type="Resource" load_steps=2 format=3]

[ext_resource type="Script" path="res://addons/block_code/code_generation/block_definition.gd" id="1_set_node_name"]

[resource]
script = ExtResource("1_set_node_name")
name = &"set_node_name"
description = "Set a node's name."
category = "Communication | Nodes"
type = 2
variant_type = 0
display_template = "set name of {node: OBJECT} to {name: STRING}"
code_template = "{node}.name = {name}"
defaults = {
"name": "Node"
}

