[gd_resource type="Resource" load_steps=2 format=3]

[ext_resource type="Script" path="res://addons/block_code/code_generation/block_definition.gd" id="1_node_get_meta"]

[resource]
script = ExtResource("1_node_get_meta")
name = &"node_get_meta"
description = "Get metadata from a node as text."
category = "Communication | Nodes"
type = 3
variant_type = 4
display_template = "metadata {key: STRING} of {node: OBJECT}"
code_template = "str({node}.get_meta({key}))"
defaults = {
"key": "key"
}
