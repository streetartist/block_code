[resource]
script = ExtResource("1_object_has_signal")
name = &"object_has_signal"
description = "True if an object has a signal with the given name."
category = "Communication | Methods"
type = 3
variant_type = 1
display_template = "{object: OBJECT} has signal {signal_name: STRING}"
code_template = "{object}.has_signal({signal_name})"
