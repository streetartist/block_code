[gd_resource type="Resource" load_steps=2 format=3]

[ext_resource type="Script" path="res://addons/block_code/code_generation/block_definition.gd" id="1_node_path_to"]

[resource]
script = ExtResource("1_node_path_to")
name = &"node_path_to"
description = "Get the path from one node to another as text."
category = "Communication | Nodes"
type = 3
variant_type = 4
display_template = "path from {from_node: OBJECT} to {to_node: OBJECT}"
code_template = "str({from_node}.get_path_to({to_node}))"
