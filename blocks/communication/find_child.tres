[gd_resource type="Resource" load_steps=2 format=3]

[ext_resource type="Script" path="res://addons/block_code/code_generation/block_definition.gd" id="1_find_child"]

[resource]
script = ExtResource("1_find_child")
name = &"find_child"
description = "Find a child node by name."
category = "Communication | Nodes"
type = 3
variant_type = 24
display_template = "find child named {name: STRING} in {node: OBJECT}"
code_template = "{node}.find_child({name}, true, false)"
defaults = {
"name": "Node"
}

