[gd_resource type="Resource" load_steps=2 format=3]

[ext_resource type="Script" path="res://addons/block_code/code_generation/block_definition.gd" id="1_wait_seconds"]

[resource]
script = ExtResource("1_wait_seconds")
name = &"wait_seconds"
target_node_class = ""
description = "Wait for the given number of seconds before continuing."
category = "Loops"
type = 2
variant_type = 0
display_template = "wait {seconds: FLOAT} seconds"
code_template = "await get_tree().create_timer({seconds}).timeout"
defaults = {
"seconds": 1.0
}
signal_name = ""
scope = ""
