[gd_resource type="Resource" load_steps=2 format=3]

[ext_resource type="Script" path="res://addons/block_code/code_generation/block_definition.gd" id="1_action_just_pressed"]

[resource]
script = ExtResource("1_action_just_pressed")
name = &"action_just_pressed"
description = "Whether an input action was just pressed this frame."
category = "Input"
type = 3
variant_type = 1
display_template = "action {action_name: STRING_NAME} was just pressed"
code_template = "Input.is_action_just_pressed('{action_name}')"
defaults = {
"action_name": "ui_accept"
}
