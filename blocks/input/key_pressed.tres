[gd_resource type="Resource" load_steps=2 format=3]

[ext_resource type="Script" path="res://addons/block_code/code_generation/block_definition.gd" id="1_key_pressed"]

[resource]
script = ExtResource("1_key_pressed")
name = &"key_pressed"
description = "True if the given keyboard key is currently pressed."
category = "Input"
type = 3
variant_type = 1
display_template = "key {key: STRING} is pressed"
code_template = "Input.is_key_pressed(OS.find_keycode_from_string({key}))"
defaults = {
"key": "Space"
}
