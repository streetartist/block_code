[gd_resource type="Resource" load_steps=2 format=3]

[ext_resource type="Script" path="res://addons/block_code/code_generation/block_definition.gd" id="1_joy_button_pressed"]

[resource]
script = ExtResource("1_joy_button_pressed")
name = &"joy_button_pressed"
description = "Whether a joypad button is pressed."
category = "Input"
type = 3
variant_type = 1
display_template = "joypad {device: INT} button {button: INT} is pressed"
code_template = "Input.is_joy_button_pressed({device}, {button})"
defaults = {
"button": 0,
"device": 0
}
