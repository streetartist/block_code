[gd_resource type="Resource" load_steps=2 format=3]

[ext_resource type="Script" path="res://addons/block_code/code_generation/block_definition.gd" id="1_action_raw_strength"]

[resource]
script = ExtResource("1_action_raw_strength")
name = &"action_raw_strength"
description = "Get the raw strength of an input action, before deadzone processing."
category = "Input"
type = 3
variant_type = 3
display_template = "raw strength of action {action_name: STRING_NAME}"
code_template = "Input.get_action_raw_strength('{action_name}')"
defaults = {
"action_name": &"ui_accept"
}
