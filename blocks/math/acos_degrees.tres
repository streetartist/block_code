[ext_resource type="Script" path="res://addons/block_code/code_generation/block_definition.gd" id="1_acos_degrees"]

[resource]
script = ExtResource("1_acos_degrees")
name = &"acos_degrees"
description = "Arccosine in degrees."
category = "Math"
type = 3
variant_type = 3
display_template = "acos degrees of {value: FLOAT}"
