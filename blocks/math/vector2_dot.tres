[ext_resource type="Script" path="res://addons/block_code/code_generation/block_definition.gd" id="1_vector2_dot"]

[resource]
script = ExtResource("1_vector2_dot")
name = &"vector2_dot"
description = "Calculate the dot product of two Vector2 values."
category = "Math"
type = 3
variant_type = 3
display_template = "dot product of {a: VECTOR2} and {b: VECTOR2}"
code_template = "{a}.dot({b})"
defaults = {
"a": Vector2(1, 0),
"b": Vector2(0, 1)
}
