[resource]
script = ExtResource("1_color_darkened")
name = &"color_darkened"
description = "Get a darker version of a color."
category = "Graphics | Modulate"
type = 3
variant_type = 20
display_template = "{color: COLOR} darkened by {amount: FLOAT}"
code_template = "{color}.darkened({amount})"
defaults = {
