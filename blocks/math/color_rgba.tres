[ext_resource type="Script" path="res://addons/block_code/code_generation/block_definition.gd" id="1_color_rgba"]

[resource]
script = ExtResource("1_color_rgba")
name = &"color_rgba"
description = "Create a color from red, green, blue, and alpha values from 0 to 1."
category = "Graphics | Modulate"
type = 3
variant_type = 20
display_template = "color red {red: FLOAT} green {green: FLOAT} blue {blue: FLOAT} alpha {alpha: FLOAT}"
code_template = "Color({red}, {green}, {blue}, {alpha})"
defaults = {
"red": 1.0,
"green": 1.0,
"blue": 1.0,
"alpha": 1.0
}
