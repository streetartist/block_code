[ext_resource type="Script" path="res://addons/block_code/code_generation/block_definition.gd" id="1_modulo"]

[resource]
script = ExtResource("1_modulo")
name = &"modulo"
description = "Get the floating point remainder after division."
category = "Math"
type = 3
variant_type = 3
display_template = "{a: FLOAT} modulo {b: FLOAT}"
code_template = "fmod({a}, {b})"
defaults = {
"a": 5.0,
"b": 2.0
}
