[gd_resource type="Resource" load_steps=2 format=3]

[ext_resource type="Script" path="res://addons/block_code/code_generation/block_definition.gd" id="1_snapped"]

[resource]
script = ExtResource("1_snapped")
name = &"snapped"
description = "Snap a number to the nearest multiple of a step."
category = "Math"
type = 3
variant_type = 3
display_template = "snap {value: FLOAT} to step {step: FLOAT}"
code_template = "snappedf({value}, {step})"
defaults = {
"value": 5.5,
"step": 1.0
}
