[ext_resource type="Script" path="res://addons/block_code/code_generation/block_definition.gd" id="1_set_node_global_position"]

[resource]
script = ExtResource("1_set_node_global_position")
name = &"set_node_global_position"
description = "Set the global position of a Node2D or Control node."
category = "Transform | Position"
type = 2
variant_type = 0
display_template = "set {node: OBJECT} global position to {position: VECTOR2}"
code_template = "{node}.global_position = {position}"
defaults = {
"position": Vector2(100, 100)
}

