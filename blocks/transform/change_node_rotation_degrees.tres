[gd_resource type="Resource" load_steps=2 format=3]

[ext_resource type="Script" path="res://addons/block_code/code_generation/block_definition.gd" id="1_change_node_rotation_degrees"]

[resource]
script = ExtResource("1_change_node_rotation_degrees")
name = &"change_node_rotation_degrees"
description = "Rotate a Node2D by degrees."
category = "Transform | Rotation"
type = 2
variant_type = 0
display_template = "change {node: OBJECT} rotation degrees by {degrees: FLOAT}"
code_template = "{node}.rotation_degrees += {degrees}"
defaults = {
"degrees": 1.0
}

