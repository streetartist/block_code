[gd_resource type="Resource" load_steps=2 format=3]

[ext_resource type="Script" path="res://addons/block_code/code_generation/block_definition.gd" id="1_string_length"]

[resource]
script = ExtResource("1_string_length")
name = &"string_length"
description = "Get the number of characters in a string."
category = "Log"
type = 3
variant_type = 2
display_template = "length of {text: STRING}"
code_template = "{text}.length()"
defaults = {
"text": "Hello"
}
