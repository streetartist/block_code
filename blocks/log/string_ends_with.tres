[gd_resource type="Resource" load_steps=2 format=3]

[ext_resource type="Script" path="res://addons/block_code/code_generation/block_definition.gd" id="1_string_ends_with"]

[resource]
script = ExtResource("1_string_ends_with")
name = &"string_ends_with"
description = "True if a string ends with another string."
category = "Log"
type = 3
variant_type = 1
display_template = "{text: STRING} ends with {suffix: STRING}"
code_template = "{text}.ends_with({suffix})"
defaults = {
"text": "Hello",
"suffix": "lo"
}
