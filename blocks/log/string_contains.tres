[gd_resource type="Resource" load_steps=2 format=3]

[ext_resource type="Script" path="res://addons/block_code/code_generation/block_definition.gd" id="1_string_contains"]

[resource]
script = ExtResource("1_string_contains")
name = &"string_contains"
description = "True if a string contains another string."
category = "Log"
type = 3
variant_type = 1
display_template = "{text: STRING} contains {piece: STRING}"
code_template = "{text}.contains({piece})"
defaults = {
"text": "Hello",
"piece": "ell"
}
