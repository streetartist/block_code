[gd_resource type="Resource" load_steps=2 format=3]

[ext_resource type="Script" path="res://addons/block_code/code_generation/block_definition.gd" id="1_print_rich"]

[resource]
script = ExtResource("1_print_rich")
name = &"print_rich"
description = "Print rich text to the output console."
category = "Log"
type = 2
variant_type = 0
display_template = "print rich {message: STRING}"
code_template = "print_rich({message})"
defaults = {
"message": "[b]Hello[/b]"
}
