[gd_resource type="Resource" load_steps=2 format=3]

[ext_resource type="Script" path="res://addons/block_code/code_generation/block_definition.gd" id="1_string_to_upper"]

[resource]
script = ExtResource("1_string_to_upper")
name = &"string_to_upper"
description = "Convert a string to uppercase."
category = "Log"
type = 3
variant_type = 4
display_template = "{text: STRING} to uppercase"
code_template = "{text}.to_upper()"
defaults = {
"text": "Hello"
}
