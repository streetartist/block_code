[gd_resource type="Resource" load_steps=2 format=3]

[ext_resource type="Script" path="res://addons/block_code/code_generation/block_definition.gd" id="1_set_node_visible"]

[resource]
script = ExtResource("1_set_node_visible")
name = &"set_node_visible"
description = "Set whether a CanvasItem node is visible."
category = "Graphics | Visibility"
type = 2
variant_type = 0
display_template = "set {node: OBJECT} visible to {visible: BOOL}"
code_template = "{node}.visible = {visible}"
defaults = {
"visible": true
}

