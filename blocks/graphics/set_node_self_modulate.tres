[gd_resource type="Resource" load_steps=2 format=3]

[ext_resource type="Script" path="res://addons/block_code/code_generation/block_definition.gd" id="1_set_node_self_modulate"]

[resource]
script = ExtResource("1_set_node_self_modulate")
name = &"set_node_self_modulate"
description = "Set a CanvasItem node's self modulate color."
category = "Graphics | Modulate"
type = 2
variant_type = 0
display_template = "set {node: OBJECT} self modulate to {color: COLOR}"
code_template = "{node}.self_modulate = {color}"
defaults = {
"color": Color(1, 1, 1, 1)
}
