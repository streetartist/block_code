[gd_resource type="Resource" load_steps=2 format=3]

[ext_resource type="Script" path="res://addons/block_code/code_generation/block_definition.gd" id="1_animated_sprite2d_play"]

[resource]
script = ExtResource("1_animated_sprite2d_play")
name = &"animated_sprite2d_play"
target_node_class = "AnimatedSprite2D"
description = "Play an AnimatedSprite2D animation."
category = "Graphics | Animation"
type = 2
variant_type = 0
display_template = "play sprite animation {animation_name: STRING_NAME}"
code_template = "play('{animation_name}')"
defaults = {
"animation_name": "default"
}
