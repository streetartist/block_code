[ext_resource type="Script" path="res://addons/block_code/code_generation/block_definition.gd" id="1_progress_bar_set_value"]

[resource]
script = ExtResource("1_progress_bar_set_value")
name = &"progress_bar_set_value"
target_node_class = "Range"
description = "Set the value for a progress bar, slider, or other range control."
category = "UI"
type = 2
variant_type = 0
display_template = "set value to {value: FLOAT}"
